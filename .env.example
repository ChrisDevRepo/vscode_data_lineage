# Integration test DB connection (test-internal/)
# Copy this file to .env and fill in your values.
# Prerequisites: SQL Server with TCP/IP enabled, Mixed Mode auth,
# GRANT VIEW SERVER STATE to login, db_owner role per database.
# See test-internal/README.md for full setup instructions.

DB_SERVER=localhost
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
DB_USER=datalineage_test
DB_PASSWORD=
DB_DATABASE_AW=AdventureWorks2025
DB_DATABASE_AW_DW=AdventureWorksDW2025

# Optional: comma-separated schema filter for Phase 2 (empty = all schemas)
DB_SCHEMAS=

# Optional: path to customer dacpac for snapshot-deps baseline (gitignored)
CUSTOMER_DACPAC_PATH=customer-data/dacpac/Synapse_Data_Warehouse.dacpac
