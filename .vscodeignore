# Source files (bundled into out/ and dist/)
src/**
test/**
customer-data/**
temp-old-design/**
tmp/**
tmp_*

# Config files
.gitignore
tsconfig.json
tsconfig.extension.json
vite.config.ts
tailwind.config.js
postcss.config.js
esbuild.config.mjs

# Dev artifacts
node_modules/**
.vscode/**
**/*.map

# Documentation (not needed in extension package)
docs/**
CONTRIBUTING.md

# Integration test infrastructure (internal only — never in VSIX)
scripts/**

# Internal test infrastructure (gitignored, must not leak into VSIX)
test-internal/**

# Environment files (must never be packaged)
.env
.env.*

# Claude Code session temp files (created by Claude CLI — must not leak into VSIX)
tmpclaude-*

# Misc
PLAN*.md
CLAUDE.md
SECURITY.md
CODE_OF_CONDUCT.md
*.vsix
debug.log
.claude/**
.github/**
**/.DS_Store
.editorconfig
.eslintrc*
.prettierrc*
