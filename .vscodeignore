# Source files (bundled into out/ and dist/)
src/**
test/**
tests/**
test-results/**
customer-data/**
temp-old-design/**
tmp/**
tmp_*

# Config files
.gitignore
tsconfig.json
tsconfig.extension.json
vite.config.ts
vitest.config.ts
tailwind.config.js
postcss.config.js
esbuild.config.mjs

# Dev artifacts
node_modules/**
.vscode/**
**/*.map

# Documentation (not needed in extension package)
docs/**
CONTRIBUTING.md

# Integration test infrastructure (internal only — never in VSIX)
scripts/**

# Internal test and documentation infrastructure (must not leak into VSIX)
test-internal/**
docs-internal/**
**/*internal*/**

# Environment files (must never be packaged)
.env
.env.*

# Claude Code session temp files (created by Claude CLI — must not leak into VSIX)
tmpclaude-*

# Stray root-level scripts/files (not part of extension)
manual-trace.ts
*batch_alloc*
bb_result.json
*ct_hop*.json

# AI dev artifacts (eval runs, replay JSON, prompt changelogs — internal only)
ai/**

# Misc
PLAN*.md
CLAUDE.md
SECURITY.md
CODE_OF_CONDUCT.md
*.vsix
debug.log
.claude/**
.github/**
**/.DS_Store
.editorconfig
.eslintrc*
.prettierrc*
