# Source files (bundled into out/ and dist/)
src/**
test/**
tests/**
test-results/**
customer-data/**
temp-old-design/**
tmp/**
tmp_*

# Test output emitted into out/ folder must not ship.
# Pattern intentionally globs `out/test*/**` so orphaned timestamped dirs
# like `out/test.stale.1777052232/` don't leak into the VSIX.
out/test*/**

# Config files
.gitignore
tsconfig.json
tsconfig.extension.json
vite.config.ts
vitest.config.ts
tailwind.config.js
postcss.config.js
esbuild.config.mjs

# Dev artifacts
node_modules/**
.vscode/**
**/*.map

# Documentation (not needed in extension package)
docs/**
CONTRIBUTING.md

# Internal test and documentation infrastructure (must not leak into VSIX)
**/*internal*/**

# Environment files (must never be packaged)
.env
.env.*

# Claude Code session temp files (created by Claude CLI — must not leak into VSIX)
tmpclaude-*

# Unreferenced screenshot (superseded by viz-search/viz-ai variants).
# NOTE: logo.png IS used at runtime by src/panelProvider.ts — keep it.
images/viz-screenshot.png

# KaTeX TTF fonts — never loaded by VS Code's webview (Chromium picks
# woff2 > woff > ttf; TTF only matters for legacy browsers). Keep woff+woff2
# as the actual delivery formats.
dist/assets/KaTeX_*.ttf

# AI dev artifacts (eval runs, replay JSON, prompt changelogs — internal only)
ai/**

# Misc
PLAN*.md
AGENTS.md
CLAUDE.md
GEMINI.md
SECURITY.md
CODE_OF_CONDUCT.md
*.vsix
debug.log
.claude/**
.github/**
**/.DS_Store
.editorconfig
.eslintrc*
.prettierrc*
