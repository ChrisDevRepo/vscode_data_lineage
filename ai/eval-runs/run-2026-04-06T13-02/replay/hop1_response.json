        "ct_ddl": "-- Level 2a: renames OrderQty→Qty, joins DimCalendar for filter ONLY\nCREATE VIEW [ai].[vwConsolidatedSales]\nAS\n    SELECT\n        s.StagingID,\n        s.OrderQty         AS Qty,\n        s.OrderAmount,\n        s.RegionCode,\n        s.OrderDate,\n        s.CustomerID,\n        s.CustomerName\n    FROM [ai].[SalesStaging] s\n    -- DimCalendar is a FILTER-ONLY join: no columns selected from dc\n    INNER JOIN [ai].[DimCalendar] dc\n        ON s.OrderDateKey = dc.DateKey\n    WHERE dc.FiscalYear = YEAR(GETDATE())\n      AND dc.IsBusinessDay = 1",
